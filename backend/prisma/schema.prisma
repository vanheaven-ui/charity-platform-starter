// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Donor
  Beneficiary
  Partner
  Supplier
  BoardMember
  Volunteer
  Member
}

model User {
  id                Int           @id @default(autoincrement())
  name              String
  email             String        @unique
  password          String
  role              Role          @default(Donor)
  status            String
  preferredLanguage String
  deviceToken       String?       // New field for mobile push notifications
  donations         Donation[]
  eventSignups      EventSignup[]
  proposals         PartnerProposal[]
  firebaseuid String? @unique
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  goal        Int
  raised      Int      @default(0)
  status      Status   @default(Active)
  donations   Donation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Donation {
  id        Int      @id @default(autoincrement())
  amount    Int
  message   String?
  donorId   Int
  projectId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  donor     User     @relation(fields: [donorId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
}

enum Status {
  Active
  Completed
  Cancelled
}

model Event {
  id            Int           @id @default(autoincrement())
  title         String
  description   String
  locationName  String
  locationLat   Float
  locationLng   Float
  eventDate     DateTime
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  eventSignups  EventSignup[]
}

model EventSignup {
  id         Int      @id @default(autoincrement())
  event      Event    @relation(fields: [eventId], references: [id])
  eventId    Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  signupDate DateTime @default(now())

  @@unique([eventId, userId])
}

model PartnerProposal {
  id        Int      @id @default(autoincrement())
  title     String
  description String
  status    ProposalStatus @default(Pending)
  partnerId Int
  partner   User     @relation(fields: [partnerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProposalStatus {
  Pending
  Approved
  Rejected
}
