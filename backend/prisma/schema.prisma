generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  name              String
  email             String            @unique
  password          String
  role              Role              @default(Donor)
  preferredLanguage String
  deviceToken       String?
  firebaseuid       String?           @unique
  status            UserStatus        @default(ACTIVE)
  donations         Donation[]
  eventSignups      EventSignup[]
  proposals         PartnerProposal[]
}

model Project {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String
  goal        Int
  raised      Int        @default(0)
  status      Status     @default(Active)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  donations   Donation[]
}

model Donation {
  id        Int      @id @default(autoincrement())
  amount    Int
  message   String?
  donorId   Int
  projectId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  donor     User     @relation(fields: [donorId], references: [id])
  project   Project  @relation(fields: [projectId], references: [id])
}

model Event {
  id           Int           @id @default(autoincrement())
  title        String
  description  String
  locationName String
  locationLat  Float
  locationLng  Float
  eventDate    DateTime
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  eventSignups EventSignup[]
}

model EventSignup {
  id         Int      @id @default(autoincrement())
  eventId    Int
  userId     Int
  signupDate DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model PartnerProposal {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  status      ProposalStatus @default(Pending)
  partnerId   Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  partner     User           @relation(fields: [partnerId], references: [id])
}

enum Role {
  Admin
  Donor
  Beneficiary
  Partner
  Supplier
  BoardMember
  Volunteer
  Member
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum Status {
  Active
  Completed
  Cancelled
}

enum ProposalStatus {
  Pending
  Approved
  Rejected
}
