generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  Admin
  Donor
  Beneficiary
  Partner
  Supplier
  BoardMember
  Volunteer
  Member
}

model User {
  id               Int     @id @default(autoincrement())
  name             String
  email            String  @unique
  password         String
  role             Role    @default(Donor)
  status           String
  preferredLanguage String
}