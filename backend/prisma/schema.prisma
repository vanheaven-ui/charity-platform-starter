generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  Admin
  Donor
  Beneficiary
  Partner
  Supplier
  BoardMember
  Volunteer
  Member
}

model User {
  id               Int     @id @default(autoincrement())
  name             String
  email            String  @unique
  password         String
  role             Role    @default(Donor)
  status           String
  preferredLanguage String
  donations         Donation[]
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  goal        Int
  raised      Int      @default(0)
  status      Status   @default(Active)
  donations   Donation[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Donation {
  id         Int      @id @default(autoincrement())
  amount     Int
  message    String?
  donorId    Int
  projectId  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  donor      User     @relation(fields: [donorId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id])
}

enum Status {
  Active
  Completed
  Cancelled
}